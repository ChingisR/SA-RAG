# ==============================================================================
# Portainer Stack Environment Variables - SA-RAG
# ==============================================================================
# Instructions:
# When deploying via Portainer "Stacks", click "Advanced mode" in the
# "Environment variables" section and paste all variables below,
# customizing values for your environment.
# ==============================================================================

# ----------------------------
# 1. Security (REQUIRED - NO DEFAULTS)
# ----------------------------
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Comma-separated list of allowed frontend origins (leave empty during development)
# Example: https://yourdomain.com,https://95.56.244.198
CORS_ORIGINS=https://10.242.102.2:8443

# ----------------------------
# 2. Database Credentials
# ----------------------------
# OpenSearch
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME_opensearch_password

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=universal_rag_db

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ----------------------------
# 3. Admin User Seed
# ----------------------------
# These are used ONLY on first boot to create the initial admin account.
# After the first deployment, changing these has NO effect.
ADMIN_EMAIL=admin@enterprise.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_admin_password

# ----------------------------
# 4. Remote GPU / Inference Nodes & SSH Testing
# ----------------------------
GPU_NODE_IP=172.19.0.1  # rag-network bridge gateway (host vLLM reachable from Docker containers)

# SSH credentials for executing automated E2E test suites inside containers remotely
SSH_HOST=10.242.102.2
SSH_PORT=22
SSH_USER=chingiz
SSH_PASSWORD=CHANGE_ME_ssh_password

# ----------------------------
# 5. Embedding Configuration
# ----------------------------
# Vector dimension output of your embedding model.
# Must be consistent between main.py and worker.py.
# Qwen3-VL-Embedding-8B produces 2048-dim (Matryoshka sliced).
EMBED_DIM=2048

# ----------------------------
# 6. Upload Controls
# ----------------------------
# Maximum allowed PDF upload size in megabytes
MAX_UPLOAD_MB=50

# ----------------------------
# 7. Web UI / Port Configurations
# ----------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ----------------------------
# 8. Observability / Metrics
# ----------------------------
# Grafana dashboard admin credentials (first boot only)
GRAFANA_USER=admin
GRAFANA_PASSWORD=ChangeMe_Grafana_2026!

# Arize Phoenix OTLP collector endpoint (internal container hostname).
# FastAPI and the Celery worker both export OpenTelemetry traces here.
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4318/v1/traces
