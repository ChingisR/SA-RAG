# Configuration template for Ingestion Agent

# SMB Connection settings
SMB_SERVER=CHANGE_ME_smb_server_ip
SMB_SHARE=CHANGE_ME_smb_share_name
SMB_USER=CHANGE_ME_smb_username
SMB_PASSWORD=CHANGE_ME_smb_password

# Destination API Settings (The URL of your SA-RAG backend)
# Because it runs over Docker Desktop or locally on your GPU node:
API_URL=http://CHANGE_ME_backend_ip:8000
API_USER=CHANGE_ME_admin_email
API_PASSWORD=CHANGE_ME_admin_password

# How often to check for new files (in seconds)
SYNC_INTERVAL_SECONDS=300
